# Match all files in any test_data directory with the following extensions
# This should cover all "big" (> ~1MB) files in the test_data directory
# Binary Earth Kernel
**/data/spice/earth*bpc filter=lfs diff=lfs merge=lfs -text

# Binary data files
**/test_data/**/*.nc filter=lfs diff=lfs merge=lfs -text
**/test_data/**/*.h5 filter=lfs diff=lfs merge=lfs -text
**/test_data/**/*.he5 filter=lfs diff=lfs merge=lfs -text
# SPICE kernels
**/test_data/**/*.bsp filter=lfs diff=lfs merge=lfs -text
**/test_data/**/*.bc filter=lfs diff=lfs merge=lfs -text
**/test_data/**/*.bpc filter=lfs diff=lfs merge=lfs -text
# Packet files (PDS and binary packet data)
**/test_data/**/*.PDS filter=lfs diff=lfs merge=lfs -text
**/test_data/packets/**/* filter=lfs diff=lfs merge=lfs -text
# Large CSV files (spice and geo data)
**/test_data/spice/*.csv filter=lfs diff=lfs merge=lfs -text
**/test_data/tier0_geo/*.csv filter=lfs diff=lfs merge=lfs -text
**/test_data/tier0_kernel/*.csv filter=lfs diff=lfs merge=lfs -text
**/test_data/tier1_geo/*.csv filter=lfs diff=lfs merge=lfs -text
# Compressed files
**/test_data/**/*.gz filter=lfs diff=lfs merge=lfs -text
# Exclude documentation and small text files from LFS
**/test_data/**/*.md !filter !diff !merge text
**/test_data/**/*.txt !filter !diff !merge text
**/test_data/**/*.yml !filter !diff !merge text
**/test_data/**/*.yaml !filter !diff !merge text
**/test_data/**/*.json !filter !diff !merge text
**/test_data/**/*.tpc !filter !diff !merge text
**/test_data/**/*.tls !filter !diff !merge text
**/test_data/**/*.tf !filter !diff !merge text
**/test_data/**/*.html !filter !diff !merge text
**/test_data/**/Dockerfile !filter !diff !merge text
# Do not store package data (libera_utils/data) in LFS or it will break our PyPI package!
**/de440.bsp filter=lfs diff=lfs merge=lfs -text
