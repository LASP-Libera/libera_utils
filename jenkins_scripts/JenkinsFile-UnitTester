/* This is a Jenkinsfile for a Jenkins job that is run once per day by Jenkins using the build periodically trigger.
*  The job is configured to discard old builds after 30 days and to only keep the last 100 builds.
*  Lastly, this job can be run manually by clicking the "Build Now" button in the Jenkins console as a parameterized
*  build. The parameter is the GIT_BRANCH variable which is used to specify which branch of the repo to build.  This is
*  set by default to origin/dev.
*
*  Note: the credentials used in the checkout step are configured in the Jenkins console as secret credentials.
*  The credentials ID can randomly generated by Jenkins and is associated with an SSH key that was generated from the
*  Bitbucket Server and uploaded to the Jenkins Server in the Manage Jenkins -> Credentials section of the Jenkins
*  console.
*
*  Finally, the Jenkins job is configured to send an email and a Slack message to the specified recipients if the job
*  fails or succeeds. Both of these are accomplished with Jenkins plugins. The email is sent using the Email Extension
*  plugin and the Slack message is sent using the Slack Notification plugin. Installation and configuration of these
*  plugins is required for this Jenkinsfile to work and are detailed on the respective plugin pages.
*/

pipeline {
    agent any
    // This lock ensures that the test database is only in use by 1 job at a time.
    options {
        lock('testdb')
    }
    stages {
        stage('Check out Repo') {
            steps {
                echo 'Checking out libera_utils repo'
                checkout([
                    $class: 'GitSCM',
                    branches: [[name: '${GIT_BRANCH}']],
                    doGenerateSubmoduleConfigurations: false,
                    gitTool: 'Default',
                    extensions: [
                            [$class: 'GitLFSPull'],
                            // [$class: 'CheckoutOption', timeout: 20],
                            // [$class: 'CloneOption',
                            //         depth: 0,
                            //         noTags: false,
                            //         reference: '/other/optional/local/reference/clone',
                            //         shallow: false,
                            //         timeout: 120]
                        ],
                    submoduleCfg: [],
                    userRemoteConfigs: [[
                        credentialsId: '2ba9f035-20ea-4b6d-b541-7378271b199a',
                        url: 'ssh://git@lasp.colorado.edu:2222/libsdc/libera_utils.git'
                        ]]
                ])
            }
        }
        // stage('Setup Dev DB') {
        //     steps {
        //         sh 'docker-compose up -d flyway-sdp-test'
        //     }
        // }
        // stage('Build Testing Image') {
        //     steps {
        //         sh 'docker-compose build tests'
        //     }
        // }
        stage('Run Tests') {
            steps {
                sh 'docker-compose up --build --exit-code-from tests tests'
            }
        }
    }

    post {
        always {
            echo "Copying test artifacts out of tests container"
            sh 'docker-compose cp tests:/opt/libera/coverage.xml .'
            sh 'docker-compose cp tests:/opt/libera/junit.xml .'

            echo "Publishing test artifacts"
            junit '**/*junit.xml'
            cobertura coberturaReportFile: '**/*coverage.xml'

            echo "Removing Docker containers"
            sh 'docker-compose down --volumes'
        }
        failure {
            emailext attachLog: true,
            body: 'Log is attached',
            subject: 'Libera Utils (libera_utils) Tests Failed',
            to: 'gavin.medley@lasp.colorado.edu,matt.watwood@lasp.colorado.edu,caleb.kumar@lasp.colorado.edu'

            slackSend color: "bad", message: "Periodic libera_utils unit tests FAILED: ${env.BUILD_URL}"
        }
    }
}
