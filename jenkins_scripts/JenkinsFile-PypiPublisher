/* This is a Jenkinsfile for a Jenkins job that is run when a tag is pushed to the libera_utils repo to publish the
*  libera_utils pacakge to PyPI.
*
*  The job uses the Generic Webhook trigger plugin to listen for the webhook from Bitbucket Server. The webhook is
*  configured to send a JSON payload that includes the tag that was pushed and is secured with a token.
*
*  The Generic Webhook trigger plugin is used to define the following environment variables:
*  - push_object: the tag that was pushed to the repo in JSONPath as $.changes[0].ref.type
*  - push_action: the action that was performed on the tag in JSONPath as $.changes[0].type
*  - pushed_tag: the tag that was pushed to the repo in JSONPath as $.changes[0].ref.displayId
*
*  The Generic Webhook trigger plugin is configured to trigger the job when a tag is pushed to the repo by using the
*  following for its Optional filter:
*  Expression = ^TAG:ADD$ - This is a regular expression that matches the text field of the Optional filter.
*  Text = $push_object:$push_action - This is the text field of the Optional filter.
*
*  The token used for pushing to PyPI is stored in the Jenkins credentials store and is accessed using the secret text
*  in the credentials plugin. This credentials is used in the `withCredentials` block to set the
*  `PYPI_TOKEN` environment variable, which is then passed into the docker image and used by Poetry to authenticate
*
*  Note: the credentials used in the checkout step are configured in the Jenkins console as secret credentials.
*  The credentials ID is randomly generated by Jenkins and is associated with an SSH key that was generated from the
*  Bitbucket Server and uploaded to the Jenkins Server in the Manage Jenkins -> Credentials section of the Jenkins
*  console.
*
*  The job checks out the tag that was pushed, builds a Python package using Poetry, and publishes it to PyPI.
*  Finally, the Jenkins job is configured to send an email and a Slack message to the specified recipients if the job
*  fails or succeeds. Both of these are accomplished with Jenkins plugins. The email is sent using the Email Extension
*  plugin and the Slack message is sent using the Slack Notification plugin. Installation and configuration of these
*  plugins is required for this Jenkinsfile to work and are detailed on the respective plugin pages.
*/
pipeline {
    agent any
    stages {
        stage('Checkout Tag') {
            steps {
                script {
                    echo "Checking out Newly Pushed Tag: ${env.pushed_tag}"
                    def scmVars = checkout([$class: 'GitSCM',
                    branches: [[name: "${env.pushed_tag}"]],
                    doGenerateSubmoduleConfigurations: false,
                    gitTool: 'Default',
                    extensions: [
                            [$class: 'GitLFSPull'],
                        ],
                    submoduleCfg: [],
                    userRemoteConfigs: [[
                        credentialsId: '2ba9f035-20ea-4b6d-b541-7378271b199a',
                        refspec: "+refs/tags/*:refs/remotes/origin/tags/*",
                        url: 'ssh://git@lasp.colorado.edu:2222/libsdc/libera_utils.git'
                        ]]
                    ])

                    this.COMMIT_HASH = scmVars.GIT_COMMIT
                    echo "Checked out tag '${env.pushed_tag}' with commit hash: ${this.COMMIT_HASH}"
                }
            }
        }
        stage('Build and Push with Poetry') {
            steps {
                withCredentials([string(credentialsId: 'libera-utils-pypi-token', variable: 'PYPI_TOKEN')]) {
                    sh 'docker-compose up --build --exit-code-from pypi-publish pypi-publish'
                }
            }
        }
    }
    post {
        always {
            echo "Removing containers"
            sh 'docker-compose down --volumes'
        }
        failure {
            emailext attachLog: true,
            body: 'Log is attached',
            subject: 'libera_utils PyPI Publish Failed',
            to: 'libera.sdp.dev.cicd@lists.lasp.colorado.edu'

            slackSend color: "bad", message: """libera_utils PyPI Publish Failed for tag ${env.pushed_tag}
            Build URL: ${env.BUILD_URL}"""
        }
        success {
            slackSend color: "good", message: """libera_utils PyPI Publish Succeeded for tag ${env.pushed_tag}
            Build URL: ${env.BUILD_URL}"""
        }
    }
}