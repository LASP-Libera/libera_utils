/* This is a Jenkinsfile for a Jenkins job that is triggered by a Bitbucket Server webhook.
*  The webhook is configured to trigger on a pull request event. The webhook is configured to
*  send a JSON payload to the Jenkins job. The Jenkins job is configured to use the Generic Webhook
*  Trigger plugin to parse the JSON payload and extract the pull request ID, the source branch, and
*  the destination branch.
*  The following payload expressions (starting with $) are used in the Generic Webhook Trigger plugin configuration to
*  create the environment variables used in this Jenkinsfile, following the pattern
*  variable_name : expression
*
*  pr_id : $.pullRequest.id
*  pr_from_ref : $.pullRequest.fromRef.id
*  pr_to_ref : $.pullRequest.toRef.id
*
*  Additionally, the Jenkins job is configured to be triggered if a specific comment is added to the pull request.
*  Any comment containing the string "run_pr_tester" will trigger this job to be run.
*  This is configured first in the Jenkins job configuration under the Generic Webhook Trigger section as a variable.
*  comment_text : $.comment.text
*  Then, in the "Optional Filter" section of the Generic Webhook Trigger plugin configuration, the following expression
*  is used to trigger the job if the comment_text variable contains the string "run_pr_tester":
*  Expression: .*run_pr_tester.*
*  Text: $comment_text
*
*  Note: the credentials used in the checkout step are configured in the Jenkins console as secret credentials.
*  The credentials ID can randomly generated by Jenkins and is associated with an SSH key that was generated from the
*  Bitbucket Server and uploaded to the Jenkins Server in the Manage Jenkins -> Credentials section of the Jenkins
*  console.
*
*  Finally, the Jenkins job is configured to send an email and a Slack message to the specified recipients if the job
*  fails or succeeds. Both of these are accomplished with Jenkins plugins. The email is sent using the Email Extension
*  plugin and the Slack message is sent using the Slack Notification plugin. Installation and configuration of these
*  plugins is required for this Jenkinsfile to work and are detailed on the respective plugin pages.
*/
def COMMIT_HASH

pipeline {
    agent any
    options {
        lock('testdb')
    }
    stages {
        stage('Checkout') {
            steps {
                echo 'Checking out PR...'
                echo "pr_id ${env.pr_id}"
                script {
                    def scmVars = checkout([$class: 'GitSCM',
                        branches: [[name: "FETCH_HEAD"]],
                        doGenerateSubmoduleConfigurations: false,
                        gitTool: 'Default',
                        extensions: [
                            [$class: 'GitLFSPull'],
                            // [$class: 'CheckoutOption', timeout: 20],
                            // [$class: 'CloneOption',
                            //         depth: 0,
                            //         noTags: false,
                            //         reference: '/other/optional/local/reference/clone',
                            //         shallow: false,
                            //         timeout: 120]
                        ],
                        submoduleCfg: [],
                        userRemoteConfigs: [[credentialsId: '2ba9f035-20ea-4b6d-b541-7378271b199a',
                            refspec: "+refs/pull-requests/${env.pr_id}/from:refs/remotes/origin/pull-requests/${env.pr_id}",
                            url: 'ssh://git@lasp.colorado.edu:2222/libsdc/libera_utils.git']]])
                    this.COMMIT_HASH = scmVars.GIT_COMMIT
                    echo this.COMMIT_HASH
                }
            }
        }
        stage('Run Pylint') {
            steps {
                sh 'docker-compose up --build --exit-code-from linting linting'
            }
        }
        stage('Run Bandit') {
            steps {
                sh 'docker-compose up --build --exit-code-from ast ast'
            }
        }
        stage('Run Tests Against Python 3.12') {
            steps {
                sh 'docker-compose up --build --exit-code-from tests tests'
            }
        }
        stage('Run Tests Against Python 3.11') {
            steps {
                sh 'docker-compose up --build --exit-code-from 3.11-tests 3.11-tests'
            }
        }
        stage('Run Tests Against Python 3.10') {
            steps {
                sh 'docker-compose up --build --exit-code-from 3.10-tests 3.10-tests'
            }
        }
        stage('Run Tests Against Python 3.9') {
            steps {
                sh 'docker-compose up --build --exit-code-from 3.9-tests 3.9-tests'
            }
        }
    }
    post {
        always {
            echo "Removing containers"
            sh 'docker-compose down --volumes'
        }
        failure {
            emailext attachLog: true,
            body: 'Log is attached',
            subject: 'libera_utils PR Tests Failed',
            to: 'gavin.medley@lasp.colorado.edu,matt.watwood@lasp.colorado.edu,caleb.kumar@lasp.colorado.edu'

            slackSend color: "bad", message: """libera_utils PR tests FAILED for PR #${env.pr_id}
            Source branch: ${env.pr_from_ref}
            Destination branch: ${env.pr_to_ref}
            Build URL: ${env.BUILD_URL}"""
        }
        success {
            slackSend color: "good", message: """libera_utils PR tester PASSED for PR #${env.pr_id}
            Source branch: ${env.pr_from_ref}
            Destination branch: ${env.pr_to_ref}
            Build URL: ${env.BUILD_URL}"""
        }
    }
}
